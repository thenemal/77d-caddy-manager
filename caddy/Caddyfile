home6.compagnie-lily.org {
	handle /.well-known/matrix/client {
		header Content-Type application/json
		respond `{"m.homeserver": {"base_url": "https://home6.compagnie-lily.org"}}`
	}
	handle /.well-known/matrix/server {
		header Content-Type application/json
		respond `{"m.server": "home6.compagnie-lily.org:443"}`
	}
	reverse_proxy /_matrix/* 192.168.45.20:8008
	reverse_proxy /_synapse/* 192.168.45.20:8008
}

